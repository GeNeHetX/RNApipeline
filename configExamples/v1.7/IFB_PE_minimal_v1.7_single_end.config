/*  MAJOR PARAMETER
* Smarter pico: 2 and --rf-stranded
* Lexogen Quantseq 3' FWD: 1 and --fr-stranded
*/
params.single_end=true
params.FeatureCountStrand = 1
params.kallistoStrand=" --fr-stranded "

/* CHOOSE YOUR RUNNING PARAMETER
*  Sequençing batch with new samples : params.routine=true
*  Process old data/project with existing md5 : params.routine=false
*/
params.routine=true
params.md5="" //ONLY if routine=false (case reprocess)

/*	Choose to run optional processes */
/* set to true or false. e.g.: params.kallisto=true runs kallisto */
params.star=true
params.fastqc=true
params.multiqc=true
params.kallisto=true
params.fcounts=true

/* Variant calling */
params.gatk4=false
params.samtools_depth=false
params.no_multimapped=false
params.mpileup=false
params.vep=false
params.vep_cache="/path/to/ensembl_v113_GRCh38/VEP"

//Mpileup parameters
params.bed = "/path/to/ROI.bed"
params.pval = 0.99 /* Don't modify value, default = 0.99*/

/*	Input of Reference Genome and transcriptome to build
* either :
*					- Pre-computed, set directory  in params.ref. Ex. params.ref="gs://pipebuff/ensembl_v105_GRCh38_GRCm39"
*					- Set params.ref="no_ref" URL for GTF, fasta, cdna and known vcf
*/

params.fasta_ref= "http://ftp.ensembl.org/pub/release-107/fasta/homo_sapiens/dna/Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz"
params.GTF= "http://ftp.ensembl.org/pub/release-107/gtf/homo_sapiens/Homo_sapiens.GRCh38.107.chr.gtf.gz"
params.known_vcf= "http://ftp.ensembl.org/pub/release-105/variation/vcf/homo_sapiens/1000GENOMES-phase_3.vcf.gz"
params.cdna= "http://ftp.ensembl.org/pub/release-107/fasta/homo_sapiens/cdna/Homo_sapiens.GRCh38.cdna.all.fa.gz"
params.idx_vep = "http://ftp.ensembl.org/pub/release-113/variation/indexed_vep_cache/homo_sapiens_vep_113_GRCh38.tar.gz"

//###########################################################################################
// DONT TOUCH BELOW
//###########################################################################################

//Deepvariant parameters
params.modelckptdeepar="/path/to/testnfcorernavar/RNAVarpipeline_deepvarversion/modules/model/"
params.nproc = 16
params.min_coverage = 3

//STAR parametrs
params.alignIntronMax =1000000
params.alignMatesGapMax= 1000000
params.limitOutSJcollapsed = 1000000
params.limitSjdbInsertNsj = 1000000
params.outFilterMultimapNmax =10
params.winAnchorMultimapNmax =50
params.alignSJoverhangMin =15
params.alignSJDBoverhangMin =1
params.alignIntronMin =20
params.outFilterMatchNminOverLread =0
params.outFilterScoreMinOverLread = 0.3
params.outFilterMismatchNmax = 33
params.outFilterMismatchNoverLmax = 0.33

//kallisto parameters
// params.bootstrap = 100
params.read_len = 120
params.read_sd=20

//Internal parameters (no need to change them)
params.picard= "/usr/local/bin/picard.jar"
params.gatk="/usr/local/gatk-4.6.1.0/gatk-package-4.6.1.0-local.jar"
params.tmpdir="./tmp/"

process {
    container= 'genehetx/genehetx-rnaseq:v1.6.0'
    errorStrategy = { task.exitStatus==14 ? 'retry' : 'terminate' }
    maxRetries = 2
   
   withName : buildref{
        cpus = 16
        memory = 40.GB
        disk = 300.GB
        }
    withName: doSTAR{
        cpus = 12
        memory = 70.GB
        disk = 500.GB
    }

withName: doOnlySTARnCount{
    cpus = 12
    memory = 70.GB
    disk = 300.GB
}
   withName: FCounts{
        cpus = 16
        memory = 16.GB
        disk = 500.GB
        container = 'nanozoo/subread:2.0.2--53f5da6'
        }
withName: KallistoPE{
        cpus = 12
        memory = 40.GB
        disk = 200.GB
        container = 'quay.io/biocontainers/kallisto:0.51.1--heb0cbe2_0'
        }
withName: Kallisto_single_end{
        cpus = 12
        memory = 20.GB
        disk = 200.GB
        container = 'quay.io/biocontainers/kallisto:0.51.1--heb0cbe2_0'
        }
  withName: gatk_vc{
        cpus = 16
        memory = 40.GB
        disk = 1.TB
        }
  withName: Vep{
        cpus = 16
        memory = 40.GB
        disk = 200.GB
        //container = 'genehetx/vep_hs:1.0'
        container = 'quay.io/biocontainers/ensembl-vep:113.2--pl5321h2a3209d_0'
        }
    withName:samtools_index{
        cpus = 4
        container = 'genehetx/genehetx-rnaseq:v1.6.0'
        memory = 10.GB
        disk = 200.GB
    }
    withName:samtools_depth{
        cpus = 4
        container = 'genehetx/genehetx-rnaseq:v1.6.0'
        memory = 10.GB
        disk = 200.GB
    }

    withName:Mosdepth{
        cpus = "${params.nproc}"
        container = 'quay.io/biocontainers/mosdepth:0.3.1--h4dc83fb_1'
    }

    withName:Bedtools{
        cpus = 1
        container = 'quay.io/biocontainers/bedtools:2.23.0--h5b5514e_6'
    }

    withName:Deepvariant{
        cpus = "${params.nproc}"
        memory = 40.GB
        disk = 500.GB
        container = 'google/deepvariant:1.4.0'
    }

  withName:multiqc{
        cpus = 4
        memory = 10.GB
        disk = 200.GB
        container = 'quay.io/biocontainers/multiqc:1.25.1--pyhdfd78af_0'
        }
  withName:fastqc{
        cpus = 4
        container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
        memory = 8.GB
        disk = 200.GB
    }

  withName:Create_md5{
        container = 'genehetx/python3.11-pd_np:latest'
        }

  withName:Verify_md5{
        container = 'genehetx/python3.11-pd_np:latest'
        }
 withName:Check_samples{
        container = 'genehetx/python3.11-pd_np:latest'
        }
 withName:Check_process{
        container = 'genehetx/python3.11-pd_np:latest'
        }

}

executor {
    name = 'slurm'
    queueSize = 20
}

cleanup = false


// Enable sigularity here
apptainer {
  enabled = true
  autoMounts = true
  envWhitelist = 'TMPDIR,NXF_TASK_WORKDIR,NXF_DEBUG'
}


report.enabled = true
trace.enabled = true

report.overwrite = true
trace.overwrite = true
